# ── Muster-Konfiguration für das Docker-Deployment ───────────────────────────
# 1. Kopieren:   cp .env.example .env
# 2. Werte unten eintragen und .env GEHEIM halten (ist via .gitignore ausgeschlossen).
# Diese Datei wird von `docker compose` automatisch eingelesen.

# Docker-Hub-Image — DEINUSER durch deinen Docker-Hub-Benutzernamen ersetzen:
IMAGE=DEINUSER/quellensteckbriefe:latest

# Team-Passwort für die internen Ansichten.
# PFLICHT setzen — ohne diese Variable nutzt die App den Default "wlo-intern"!
QE_TEAM_PASSWORD=bitte-ein-sicheres-passwort-setzen

# Host-Port für die einfache HTTP-Variante (docker-compose.yml); im Container
# lauscht die App auf 8080:
PORT=8080

# Nur für die HTTPS-Variante (docker-compose.tls.yml): Hostname via nip.io/sslip.io.
# Format: <label>.<DEINE-SERVER-IP>.nip.io  (die Punkte der IP bleiben Punkte)
SITE_ADDRESS=quellensteckbriefe.31.70.69.94.nip.io
