# Quellensteckbriefe-App — Umgebungsvariablen (MUSTER)
# Kopiere diese Datei nach ".env" und passe die Werte an.
# (.env wird NICHT versioniert; echte Shell-Umgebungsvariablen haben Vorrang.)

# Team-Passwort für den internen Bereich (Zustand, genauer Erschliessungsstatus,
# Vertrag/Vereinbarung), die Admin-Endpoints (/api/admin/reload) UND den Live-Refresh
# (/jobs/refresh, Button "Aktualisieren") — der ist team-geschuetzt, NICHT oeffentlich.
# KEIN Default: ohne gesetzten Wert sind alle Team-Funktionen deaktiviert (fail closed).
QE_TEAM_PASSWORD=bitte-ein-sicheres-passwort-setzen

# Optionaler naechtlicher Auto-Refresh der Live-Daten: Stunde 0-23 (lokale Zeit),
# z. B. 3 = taeglich 03:00 Uhr. Leer/weglassen = aus.
QE_AUTO_REFRESH_HOUR=
