# Quellensteckbriefe-App — Umgebungsvariablen (MUSTER)
# Kopiere diese Datei nach ".env" und passe die Werte an.
# (.env wird NICHT versioniert; echte Shell-Umgebungsvariablen haben Vorrang.)

# Team-Passwort für den internen Bereich (Zustand, genauer Erschliessungsstatus,
# Vertrag/Vereinbarung) und passwortgeschuetzte Admin-Endpoints (/api/admin/reload).
# Wenn leer/ungesetzt, gilt der Default "wlo-intern".
# Hinweis: Der Live-Refresh (/jobs/refresh, Button "Aktualisieren") ist OEFFENTLICH
# und benoetigt KEIN Passwort.
QE_TEAM_PASSWORD=wlo-intern
